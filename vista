<?php
// 1. Incluimos la conexión a Supabase
$pdo = require 'conexion.php';

try {
    // 2. Consultar los datos de las Vistas de Supabase
    $stmtDiario = $pdo->query("SELECT * FROM reporte_ventas_diarias ORDER BY fecha DESC, total_individual_producto DESC");
    $reporteDiario = $stmtDiario->fetchAll();

    $stmtMensual = $pdo->query("SELECT * FROM reporte_ventas_mensuales ORDER BY mes DESC, total_individual_producto DESC");
    $reporteMensual = $stmtMensual->fetchAll();

    // 3. Obtener valores para las tarjetas de resumen (KPIs) de manera dinámica
    $totalHoy = !empty($reporteDiario) ? $reporteDiario[0]['total_general_del_dia'] : 0.00;
    $totalMes = !empty($reporteMensual) ? $reporteMensual[0]['total_general_del_mes'] : 0.00;
    
    // Consultar cuántos productos están por debajo del stock mínimo
    $stmtAlertas = $pdo->query("SELECT COUNT(*) as alertas FROM productos WHERE stock_actual <= stock_minimo AND activo = true");
    $alertasStock = $stmtAlertas->fetch()['alertas'];

} catch (PDOException $e) {
    die("Error al cargar el panel de control: " . $e->getMessage());
}
